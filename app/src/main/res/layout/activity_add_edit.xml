<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Titre dynamique (Ajouter / Modifier) -->
        <TextView
            android:id="@+id/tvTitreFormulaire"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ajouter un prêt"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="24dp" />

        <!-- Nom du client -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nom du client"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etNomClient"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ex : Jean Rakoto"
            android:inputType="textPersonName"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Nom de la banque -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nom de la banque"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etNomBanque"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ex : BNI Madagascar"
            android:inputType="text"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Montant -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Montant du prêt (Ar)"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etMontant"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ex : 5000000"
            android:inputType="numberDecimal"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Date du prêt -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date du prêt"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etDatePret"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="YYYY-MM-DD"
            android:inputType="date"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="16dp" />

        <!-- Taux du prêt -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Taux du prêt (ex: 0.12 pour 12%)"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etTauxPret"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Ex : 0.12"
            android:inputType="numberDecimal"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Aperçu montant à payer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Montant à payer estimé :"
                android:textSize="13sp"
                android:textColor="#1565C0" />

            <TextView
                android:id="@+id/tvPreviewMAP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#C62828" />
        </LinearLayout>

        <!-- Boutons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAnnuler"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Annuler"
                android:textColor="#1565C0"
                android:backgroundTint="#FFFFFF"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnEnregistrer"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Enregistrer"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>